# ============================================
# KYC Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Usage: export $(cat .env | xargs) && go run ./cmd/server

# --- REQUIRED FOR LOCAL & PRODUCTION ---

# PostgreSQL connection string
# Railway: Select DATABASE_URL from your auto-provisioned Postgres plugin via "Reference Variable".
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://sarthak:@localhost:5432/kyc_dev?sslmode=disable

# JWT signing secret (minimum 32 characters)
# Railway: Generate a random string using `openssl rand -hex 32` or an online generator.
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# --- OPTIONAL / DEFAULTS ---

# Server port (Railway injects PORT automatically, only needed locally)
PORT=8080

# File storage backend: "local" or "s3"
# Railway: Keep this as "local" when using Railway Persistent Volumes to avoid S3 requirements!
STORAGE_BACKEND=local

# Local storage directory (used when STORAGE_BACKEND=local)
# Railway: Must be set to `/app/uploads` and perfectly match your Persistent Volume mount path!
STORAGE_ROOT=./uploads

# AWS S3 config (required only when STORAGE_BACKEND=s3)
# AWS_BUCKET=my-kyc-bucket
# AWS_REGION=ap-south-1
