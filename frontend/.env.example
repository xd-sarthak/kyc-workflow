# ============================================
# KYC Frontend — Environment Configuration
# ============================================
# Vite automatically loads variables that start with "VITE_"
# Note: You only need to configure this when your frontend is deployed 
# separately from your backend (e.g., on Vercel connecting to a Railway backend).

# The base URL of the Go backend API. 
# VITE_API_URL=https://your-generated-railway-url.up.railway.app/api/v1
